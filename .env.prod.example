# ============================================================
# 龙虾超市 生产环境配置模板
# ⚠️ 复制为 .env.prod 后填入真实值，.env.prod 不入代码仓库
# ============================================================

# ----- 应用 -----
APP_NAME=lobstermart
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=（生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"）

# ----- 数据库 -----
DATABASE_URL=postgresql+asyncpg://用户名:密码@数据库地址:5432/lobstermart
DATABASE_ECHO=false

# ----- Redis -----
REDIS_URL=redis://:密码@Redis地址:6379/0


# ----- JWT -----
JWT_SECRET=（同上方式生成一个独立的随机密钥）
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- 对象存储（生产用阿里云 OSS）-----
STORAGE_BACKEND=oss
OSS_ENDPOINT=oss-cn-wuhan-lr.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=lobstermart-prod
OSS_CDN_DOMAIN=cdn.lobstermart.com

# ----- 支付宝正式环境 -----
ALIPAY_APP_ID=（正式应用的 APPID）
ALIPAY_PID=（正式应用绑定的商家 PID）
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_PRIVATE_KEY=（正式应用的私钥）
ALIPAY_PUBLIC_KEY=（正式应用的支付宝公钥）
ALIPAY_NOTIFY_URL=https://你的域名/api/v1/payments/alipay/notify

# ----- Celery -----
CELERY_BROKER_URL=redis://:密码@Redis地址:6379/1
CELERY_RESULT_BACKEND=redis://:密码@Redis地址:6379/2

# ----- 钱包 -----
WITHDRAW_MIN_AMOUNT=100.00
WITHDRAW_COOLDOWN_DAYS=7
PLATFORM_FEE_RATE=0.30

# ----- CORS -----
CORS_ORIGINS=["https://你的域名"]
