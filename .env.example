# ============================================================
# PrivClaw 环境变量配置模板
# 复制为 .env 后填入真实值，.env 文件不入代码仓库
# ============================================================

# ----- 应用 -----
APP_NAME=privclaw
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=（生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"）

# ----- 数据库 -----
DATABASE_URL=postgresql+asyncpg://privclaw:privclaw123@postgres:5432/privclaw
DATABASE_ECHO=false

# ----- Redis -----
REDIS_URL=redis://:${REDIS_PASSWORD:-redis123}@redis:6379/0

# ----- JWT -----
JWT_SECRET=（生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"）
JWT_ALGORITHM=HS256
# RS256 模式配置（JWT_ALGORITHM=RS256 时生效）
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- 敏感数据加密 -----
DATA_ENCRYPTION_KEY=（生成方式: python -c "from app.core.encryption import DataEncryption; print(DataEncryption.generate_key())"）

# ----- 对象存储（开发用 MinIO，生产用阿里云 OSS）-----
STORAGE_BACKEND=minio
# MinIO（开发环境）
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=privclaw
MINIO_USE_SSL=false
MINIO_EXTERNAL_ENDPOINT=localhost:9000
# 阿里云 OSS（生产环境，切换 STORAGE_BACKEND=oss 时生效）
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=privclaw-prod
OSS_CDN_DOMAIN=

# ----- 支付宝（沙箱环境）-----
ALIPAY_APP_ID=
ALIPAY_PID=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# ----- Celery -----
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD:-redis123}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD:-redis123}@redis:6379/2

# ----- 业务参数 -----
WITHDRAW_MIN_AMOUNT=100.00
WITHDRAW_COOLDOWN_DAYS=7
PLATFORM_FEE_RATE=0.30

# ----- CORS -----
CORS_ORIGINS=["http://localhost:3000"]
